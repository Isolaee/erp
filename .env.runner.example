# Copy this to .env.runner (gitignored) and fill in the values.
#
# GH_RUNNER_TOKEN — GitHub Personal Access Token used to register the runner.
#
#   Classic PAT (easiest):
#     GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
#     Required scope: repo  (full control — needed to post commit/PR statuses)
#
#   Fine-grained PAT (scoped to this repo):
#     GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
#     Repository: Isolaee/erp
#     Permissions:
#       Actions        → Read and write
#       Administration → Read and write   (runner registration)
#       Metadata       → Read-only (mandatory)
#
GH_RUNNER_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: give the runner a recognisable name in the GitHub UI.
RUNNER_NAME=local-docker-runner
