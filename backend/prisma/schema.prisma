generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEAM_LEAD
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum TaskAssignmentStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  REJECTED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ListScope {
  ORGANIZATION
  TEAM
  PERSONAL
}

enum DocVisibility {
  PRIVATE
  TEAM
  ORGANIZATION
}

enum ListVisibility {
  PRIVATE
  TEAM
  ORGANIZATION
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String?
  githubId     String?   @unique
  githubToken  String?
  role         UserRole  @default(MEMBER)
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  teamMemberships  TeamMember[]
  ownedLists       TaskList[]       @relation("ListOwner")
  createdTasks     Task[]           @relation("TaskCreator")
  taskAssignments  TaskAssignment[]
  sentInvites      Invite[]         @relation("InviteSender")
  receivedInvites  Invite[]         @relation("InviteRecipient")
  aiRefinements    AiRefinement[]
  refreshTokens    RefreshToken[]
  addedRepoFollows RepoFollow[]
  docs             Doc[]
}

model Team {
  id          String    @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members     TeamMember[]
  taskLists   TaskList[]
  repoFollows RepoFollow[]
  invites     Invite[]
  docs        Doc[]
}

model TeamMember {
  id       String   @id @default(uuid())
  userId   String
  teamId   String
  role     UserRole @default(MEMBER)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

model Invite {
  id          String       @id @default(uuid())
  token       String       @unique @default(uuid())
  email       String?
  teamId      String?
  senderId    String
  recipientId String?
  role        UserRole     @default(MEMBER)
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())
  acceptedAt  DateTime?

  sender    User  @relation("InviteSender", fields: [senderId], references: [id])
  recipient User? @relation("InviteRecipient", fields: [recipientId], references: [id])
  team      Team? @relation(fields: [teamId], references: [id])
}

model RepoFollow {
  id            String    @id @default(uuid())
  teamId        String
  owner         String
  repo          String
  addedByUserId String?
  addedAt       DateTime  @default(now())
  lastSyncAt    DateTime?

  team    Team  @relation(fields: [teamId], references: [id])
  addedBy User? @relation(fields: [addedByUserId], references: [id])
  docs    Doc[]

  @@unique([teamId, owner, repo])
}

model TaskList {
  id          String         @id @default(uuid())
  title       String
  description String?
  scope       ListScope
  visibility  ListVisibility @default(PRIVATE)
  ownerId     String
  teamId      String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  ownerUser User  @relation("ListOwner", fields: [ownerId], references: [id])
  team      Team?  @relation(fields: [teamId], references: [id])
  tasks     Task[]
}

model Task {
  id          String       @id @default(uuid())
  listId      String
  parentId    String?
  title       String
  description String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  order       Float        @default(0)
  creatorId   String
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  list          TaskList         @relation(fields: [listId], references: [id])
  parent        Task?            @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks      Task[]           @relation("TaskSubtasks")
  creator       User             @relation("TaskCreator", fields: [creatorId], references: [id])
  assignments   TaskAssignment[]
  aiRefinements AiRefinement[]

  @@index([listId])
  @@index([parentId])
}

model TaskAssignment {
  id           String               @id @default(uuid())
  taskId       String
  assigneeId   String
  assignedById String?
  status       TaskAssignmentStatus @default(PENDING_ACCEPTANCE)
  note         String?
  responseNote String?
  createdAt    DateTime             @default(now())
  respondedAt  DateTime?

  task     Task @relation(fields: [taskId], references: [id])
  assignee User @relation(fields: [assigneeId], references: [id])

  @@unique([taskId, assigneeId])
}

model AiRefinement {
  id          String   @id @default(uuid())
  taskId      String?
  listId      String?
  docId       String?
  prompt      String
  response    String
  toolCalls   Json     @default("[]")
  createdById String
  createdAt   DateTime @default(now())

  task      Task? @relation(fields: [taskId], references: [id])
  doc       Doc?  @relation(fields: [docId], references: [id])
  createdBy User  @relation(fields: [createdById], references: [id])
}

model Doc {
  id             String        @id @default(uuid())
  title          String
  content        String        @db.Text
  visibility     DocVisibility @default(PRIVATE)
  ownerId        String
  teamId         String?
  repoFollowId   String?
  lastAutoSyncAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  owner         User          @relation(fields: [ownerId], references: [id])
  team          Team?         @relation(fields: [teamId], references: [id])
  repoFollow    RepoFollow?   @relation(fields: [repoFollowId], references: [id])
  sections      DocSection[]
  aiRefinements AiRefinement[]

  @@index([title])
  @@index([ownerId])
  @@index([teamId])
  @@index([repoFollowId])
}

model DocSection {
  id        String   @id @default(uuid())
  docId     String
  heading   String
  content   String   @db.Text
  level     Int
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doc Doc @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId])
  @@index([docId, order])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id])
}
