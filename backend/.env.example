# Docker Compose: use service names as hostnames
# DATABASE_URL=postgresql://erp:erp@postgres:5432/erp
# REDIS_URL=redis://redis:6379

# Local dev (no Docker):
DATABASE_URL=postgresql://erp:erp@localhost:5432/erp
# REDIS_URL=redis://localhost:6379   # optional — omit to run without Redis
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
